# WordPress + WooCommerce GraphQL endpoint (WPGraphQL + WooGraphQL plugins required)
# e.g. https://your-store.com/graphql
NEXT_PUBLIC_WP_GRAPHQL_URL=

# WordPress media hostname for Next.js Image optimisation
# e.g. your-store.com
NEXT_PUBLIC_WP_HOSTNAME=

# Public URL of this site — used for sitemap.xml and robots.txt
# e.g. https://haquemart.vercel.app
NEXT_PUBLIC_SITE_URL=
