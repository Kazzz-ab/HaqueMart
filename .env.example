# WordPress + WooCommerce GraphQL endpoint (WPGraphQL plugin required)
# e.g. https://your-store.com/graphql
NEXT_PUBLIC_WP_GRAPHQL_URL=

# WordPress media hostname for Next.js Image optimisation
# e.g. your-store.com
NEXT_PUBLIC_WP_HOSTNAME=

# Stripe (added in checkout sprint)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
